<Window
    x:Class="AppWindows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AppWindows">

    <Grid x:Name="RootGrid" RequestedTheme="Dark" Background="#080808">
        <Grid.Resources>
            <SolidColorBrush x:Key="SurfaceBrush" Color="#0D0D0E" />
            <SolidColorBrush x:Key="SidebarBrush" Color="#101011" />
            <SolidColorBrush x:Key="PanelBrush" Color="#141414" />
            <SolidColorBrush x:Key="PanelAltBrush" Color="#1B1B1B" />
            <SolidColorBrush x:Key="StrokeBrush" Color="#303030" />
            <SolidColorBrush x:Key="MutedTextBrush" Color="#8F8F8F" />
            <SolidColorBrush x:Key="SubtleTextBrush" Color="#5F5F5F" />
            <SolidColorBrush x:Key="AccentGoldBrush" Color="#A88745" />
            <SolidColorBrush x:Key="AccentGreenBrush" Color="#22C55E" />
            <SolidColorBrush x:Key="NavActiveBrush" Color="#292929" />
            <SolidColorBrush x:Key="TransparentBrush" Color="Transparent" />
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="136" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Background="{StaticResource SidebarBrush}"
            BorderBrush="{StaticResource StrokeBrush}"
            BorderThickness="0,0,1,0">
            <Grid Padding="6,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Foreground="{StaticResource MutedTextBrush}"
                    FontSize="11"
                    Text="Main menu" />

                <StackPanel
                    Grid.Row="1"
                    Margin="0,10,0,0"
                    Spacing="18">
                    <StackPanel Spacing="8">
                        <Button
                            x:Name="HomeNavButton"
                            AutomationProperties.AutomationId="HomeNavButton"
                            Height="34"
                            Padding="6,0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="{StaticResource NavActiveBrush}"
                            BorderBrush="{StaticResource AccentGoldBrush}"
                            BorderThickness="2,0,0,0"
                            Click="HomeNavButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon
                                    Width="16"
                                    Height="16"
                                    Foreground="{StaticResource MutedTextBrush}"
                                    Symbol="Home" />
                                <TextBlock
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    Text="Inicio" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock
                            Foreground="{StaticResource MutedTextBrush}"
                            FontSize="11"
                            Text="Database" />
                        <Button
                            x:Name="StudentsNavButton"
                            AutomationProperties.AutomationId="StudentsNavButton"
                            Height="30"
                            Padding="6,0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="{StaticResource TransparentBrush}"
                            BorderBrush="{StaticResource TransparentBrush}"
                            BorderThickness="2,0,0,0"
                            Click="StudentsNavButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon
                                    Width="15"
                                    Height="15"
                                    Foreground="{StaticResource MutedTextBrush}"
                                    Symbol="Contact" />
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="Alumnos" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="74" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                Background="{StaticResource SurfaceBrush}">
                <Canvas Opacity="0.24">
                    <Polyline Points="0,54 70,34 140,48 210,18 280,44 350,24 420,38 490,12 560,36 630,20 700,42 770,18 840,34 910,14 980,38 1050,22 1120,40"
                              Stroke="#777777"
                              StrokeThickness="1" />
                    <Polyline Points="0,30 80,46 160,26 240,42 320,20 400,48 480,28 560,44 640,24 720,50 800,30 880,46 960,22 1040,44 1120,28"
                              Stroke="#5F5F5F"
                              StrokeThickness="1" />
                    <Polyline Points="0,66 90,58 180,68 270,46 360,62 450,44 540,64 630,50 720,66 810,46 900,62 990,42 1080,60"
                              Stroke="#686868"
                              StrokeThickness="1" />
                    <Polyline Points="0,18 75,22 150,12 225,30 300,10 375,26 450,14 525,32 600,16 675,28 750,10 825,24 900,15 975,30 1050,18"
                              Stroke="#4C4C4C"
                              StrokeThickness="1" />
                </Canvas>

                <StackPanel
                    Margin="24,13,0,0"
                    Spacing="6">
                    <TextBlock
                        x:Name="PageTitleTextBlock"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Text="Inicio" />
                    <TextBlock
                        x:Name="PageSubtitleTextBlock"
                        Foreground="{StaticResource MutedTextBrush}"
                        FontSize="12"
                        Text="Resumen principal de la autoescuela y actividad reciente." />
                </StackPanel>
            </Grid>

            <InfoBar
                x:Name="StatusInfoBar"
                Grid.Row="1"
                Margin="10,8,10,0"
                IsClosable="True"
                IsOpen="False" />

            <Grid Grid.Row="2">
                <Grid
                    x:Name="HomeView"
                    Margin="10,8,10,10"
                    RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="10">
                        <Button
                            x:Name="QuickNoteButton"
                            AutomationProperties.AutomationId="QuickNoteButton"
                            Width="180"
                            Height="48"
                            Padding="12,0"
                            HorizontalContentAlignment="Stretch"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            Click="QuickNoteButton_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Text="Notas" />
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Text="Poner una nota" />
                                </StackPanel>

                                <SymbolIcon
                                    Grid.Column="1"
                                    Width="16"
                                    Height="16"
                                    VerticalAlignment="Center"
                                    Symbol="Add" />
                            </Grid>
                        </Button>

                        <Button
                            x:Name="QuickStudentButton"
                            AutomationProperties.AutomationId="QuickStudentButton"
                            Width="180"
                            Height="48"
                            Padding="12,0"
                            HorizontalContentAlignment="Stretch"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            Click="QuickStudentButton_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Text="Alumnos" />
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Text="Crear un alumno nuevo" />
                                </StackPanel>

                                <SymbolIcon
                                    Grid.Column="1"
                                    Width="16"
                                    Height="16"
                                    VerticalAlignment="Center"
                                    Symbol="Add" />
                            </Grid>
                        </Button>
                    </StackPanel>

                    <Grid
                        Grid.Row="1"
                        ColumnSpacing="12"
                        RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="1.05*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="84" />
                            <RowDefinition Height="170" />
                            <RowDefinition Height="170" />
                        </Grid.RowDefinitions>

                        <Border
                            Grid.RowSpan="2"
                            Padding="12"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="7">
                            <Grid>
                                <SymbolIcon
                                    Width="15"
                                    Height="15"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Foreground="{StaticResource MutedTextBrush}"
                                    Symbol="Calendar" />
                                <Canvas
                                    Margin="0,28,0,0"
                                    Opacity="0.20">
                                    <Polyline Points="0,130 28,92 56,108 84,52 112,82 140,34 168,70 196,38 224,92 252,66 280,116 308,76 336,122"
                                              Stroke="#6B6B6B"
                                              StrokeThickness="1" />
                                    <Polyline Points="0,70 32,84 64,60 96,90 128,52 160,102 192,64 224,96 256,68 288,110 320,78"
                                              Stroke="#545454"
                                              StrokeThickness="1" />
                                </Canvas>
                                <StackPanel
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom"
                                    Spacing="4">
                                    <TextBlock
                                        Foreground="{StaticResource MutedTextBrush}"
                                        FontSize="12"
                                        Text="Agenda" />
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Text="Vista preparada para calendario" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border
                            Grid.Row="2"
                            Padding="16"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="7">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="7">
                                        <SymbolIcon
                                            Width="14"
                                            Height="14"
                                            Foreground="{StaticResource MutedTextBrush}"
                                            Symbol="Calendar" />
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Text="Fecha de Examenes" />
                                    </StackPanel>
                                    <Button
                                        Grid.Column="1"
                                        Width="28"
                                        Height="28"
                                        Padding="0"
                                        Background="{StaticResource TransparentBrush}"
                                        BorderBrush="{StaticResource TransparentBrush}"
                                        Click="QuickNoteButton_Click">
                                        <SymbolIcon
                                            Width="13"
                                            Height="13"
                                            Symbol="Add" />
                                    </Button>
                                </Grid>

                                <StackPanel
                                    Grid.Row="1"
                                    VerticalAlignment="Center"
                                    Spacing="12">
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Text="Febrero 15 a las 9:00" />
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Text="Marzo 23 a las 12:00" />
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Text="Enero 05 a las 13:00" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Padding="14"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="7">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Foreground="{StaticResource MutedTextBrush}"
                                    FontSize="12"
                                    Text="Alumnos activos" />
                                <TextBlock
                                    x:Name="HomeStudentTotalTextBlock"
                                    FontSize="24"
                                    FontWeight="SemiBold"
                                    Text="0" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Column="2"
                            Padding="14"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="7">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Foreground="{StaticResource MutedTextBrush}"
                                    FontSize="12"
                                    Text="Carnets / tags" />
                                <TextBlock
                                    x:Name="HomeTagTotalTextBlock"
                                    FontSize="24"
                                    FontWeight="SemiBold"
                                    Text="0" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="1"
                            Grid.Column="1"
                            Padding="14"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="7">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="7">
                                        <SymbolIcon
                                            Width="14"
                                            Height="14"
                                            Foreground="{StaticResource MutedTextBrush}"
                                            Symbol="Link" />
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Text="Citados Examen" />
                                    </StackPanel>
                                    <SymbolIcon
                                        Grid.Column="1"
                                        Width="13"
                                        Height="13"
                                        Foreground="{StaticResource MutedTextBrush}"
                                        Symbol="Edit" />
                                </Grid>

                                <StackPanel
                                    Grid.Row="1"
                                    Margin="0,12,0,0"
                                    Spacing="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            FontSize="12"
                                            Text="Pendiente de conectar" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Foreground="{StaticResource AccentGreenBrush}"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Text="24/05" />
                                    </Grid>
                                    <TextBlock
                                        Foreground="{StaticResource MutedTextBrush}"
                                        FontSize="12"
                                        Text="Modulo preparado para examenes." />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border
                            Grid.RowSpan="2"
                            Grid.Column="2"
                            Padding="14"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="7">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="7">
                                        <SymbolIcon
                                            Width="14"
                                            Height="14"
                                            Foreground="{StaticResource MutedTextBrush}"
                                            Symbol="Message" />
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Text="Ultimos Alumnos" />
                                    </StackPanel>
                                    <SymbolIcon
                                        Grid.Column="1"
                                        Width="13"
                                        Height="13"
                                        Foreground="{StaticResource MutedTextBrush}"
                                        Symbol="Edit" />
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <TextBlock
                                        x:Name="RecentStudentsEmptyTextBlock"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource MutedTextBrush}"
                                        FontSize="12"
                                        Text="Todavia no hay alumnos registrados."
                                        Visibility="Collapsed" />
                                    <ListView
                                        x:Name="RecentStudentsListView"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderThickness="0"
                                        IsItemClickEnabled="True"
                                        ItemClick="RecentStudentsListView_ItemClick"
                                        SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid
                                                    MinHeight="48"
                                                    Padding="0,6"
                                                    ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock
                                                            FontSize="13"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding FullName}" />
                                                        <TextBlock
                                                            Foreground="{StaticResource MutedTextBrush}"
                                                            FontSize="12"
                                                            Text="{Binding Phone}" />
                                                    </StackPanel>

                                                    <TextBlock
                                                        Grid.Column="1"
                                                        VerticalAlignment="Bottom"
                                                        Foreground="{StaticResource MutedTextBrush}"
                                                        FontSize="11"
                                                        Text="{Binding CreatedAtDisplay}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Grid
                    x:Name="StudentsView"
                    Margin="0,8,0,0"
                    ColumnSpacing="10"
                    Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>

                    <Grid
                        Grid.Column="0"
                        Background="{StaticResource SurfaceBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid
                            Grid.Row="0"
                            Padding="10,8"
                            ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                x:Name="SearchTextBox"
                                Height="32"
                                PlaceholderText="Search"
                                TextChanged="SearchTextBox_TextChanged" />

                            <ComboBox
                                x:Name="FilterTagComboBox"
                                Grid.Column="1"
                                Height="32"
                                DisplayMemberPath="Name"
                                SelectionChanged="FilterTagComboBox_SelectionChanged" />

                            <Button
                                x:Name="NewStudentButton"
                                Grid.Column="3"
                                Height="32"
                                Padding="10,0"
                                Click="NewStudentButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <SymbolIcon Symbol="Add" />
                                    <TextBlock Text="Nuevo" />
                                </StackPanel>
                            </Button>

                            <StackPanel
                                Grid.Column="4"
                                Orientation="Horizontal"
                                Spacing="4">
                                <Button Width="32" Height="32" Padding="0">
                                    <SymbolIcon Symbol="List" />
                                </Button>
                                <Button Width="32" Height="32" Padding="0">
                                    <SymbolIcon Symbol="ViewAll" />
                                </Button>
                            </StackPanel>
                        </Grid>

                        <StackPanel
                            Grid.Row="1"
                            Margin="10,0,0,0"
                            Orientation="Horizontal"
                            Spacing="14">
                            <TextBlock
                                Foreground="White"
                                FontSize="12"
                                Text="All" />
                            <TextBlock
                                x:Name="StudentCountTextBlock"
                                Foreground="{StaticResource MutedTextBrush}"
                                FontSize="12" />
                        </StackPanel>

                        <Border
                            Grid.Row="2"
                            Margin="0,6,0,0"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="0,0,0,1">
                            <Grid
                                Height="34"
                                Padding="12,0"
                                ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="48" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="Descripcion" />
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="Telefono" />
                                <TextBlock
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="Tags" />
                                <TextBlock
                                    Grid.Column="3"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="Alta" />
                            </Grid>
                        </Border>

                        <ListView
                            x:Name="StudentsListView"
                            Grid.Row="3"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="0"
                            SelectionChanged="StudentsListView_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid
                                        MinHeight="56"
                                        Padding="12,6"
                                        ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="48" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Border
                                                Width="18"
                                                Height="18"
                                                VerticalAlignment="Center"
                                                Background="#E4E4E4"
                                                CornerRadius="9">
                                                <SymbolIcon
                                                    Width="12"
                                                    Height="12"
                                                    Foreground="#6B6B6B"
                                                    Symbol="Contact" />
                                            </Border>

                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding FullName}" />
                                                <TextBlock
                                                    Foreground="{StaticResource MutedTextBrush}"
                                                    FontSize="11"
                                                    Text="{Binding DniNie}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Foreground="#D4D4D4"
                                            FontSize="12"
                                            Text="{Binding Phone}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Foreground="#D4D4D4"
                                            FontSize="12"
                                            Text="{Binding TagsDisplay}" />
                                        <TextBlock
                                            Grid.Column="3"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource MutedTextBrush}"
                                            FontSize="12"
                                            Text="{Binding CreatedAtDisplay}" />
                                        <SymbolIcon
                                            Grid.Column="4"
                                            Width="16"
                                            Height="16"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource MutedTextBrush}"
                                            Symbol="View" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <Border
                        Grid.Column="1"
                        Margin="0,0,10,10"
                        Padding="14"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="1">
                        <ScrollViewer>
                            <Grid RowSpacing="14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="3">
                                        <TextBlock
                                            x:Name="EditorTitleTextBlock"
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Text="Nuevo alumno" />
                                        <TextBlock
                                            x:Name="EditorSubtitleTextBlock"
                                            Foreground="{StaticResource MutedTextBrush}"
                                            FontSize="12"
                                            Text="Nombre, DNI/NIE y telefono son obligatorios" />
                                    </StackPanel>

                                    <TextBlock
                                        x:Name="CreatedAtTextBlock"
                                        Grid.Column="1"
                                        VerticalAlignment="Bottom"
                                        Foreground="{StaticResource MutedTextBrush}"
                                        FontSize="12" />
                                </Grid>

                                <TextBox
                                    x:Name="FullNameTextBox"
                                    Grid.Row="1"
                                    Header="Nombre"
                                    PlaceholderText="Nombre completo" />

                                <Grid
                                    Grid.Row="2"
                                    ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox
                                        x:Name="DniTextBox"
                                        Header="DNI/NIE"
                                        PlaceholderText="12345678A" />
                                    <TextBox
                                        x:Name="PhoneTextBox"
                                        Grid.Column="1"
                                        Header="Telefono"
                                        PlaceholderText="600 000 000" />
                                </Grid>

                                <TextBox
                                    x:Name="NotesTextBox"
                                    Grid.Row="3"
                                    AcceptsReturn="True"
                                    Header="Observaciones"
                                    Height="88"
                                    PlaceholderText="Notas internas"
                                    TextWrapping="Wrap" />

                                <StackPanel
                                    Grid.Row="4"
                                    Spacing="10">
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Text="Carnets y tags" />

                                    <ScrollViewer
                                        HorizontalScrollBarVisibility="Auto"
                                        VerticalScrollBarVisibility="Disabled">
                                        <StackPanel
                                            x:Name="TagCheckBoxesPanel"
                                            Orientation="Horizontal"
                                            Spacing="8" />
                                    </ScrollViewer>

                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox
                                            x:Name="CustomTagTextBox"
                                            PlaceholderText="Crear tag personalizado" />
                                        <Button
                                            x:Name="AddTagButton"
                                            Grid.Column="1"
                                            Padding="10,0"
                                            Click="AddTagButton_Click">
                                            <SymbolIcon Symbol="Tag" />
                                        </Button>
                                    </Grid>
                                </StackPanel>

                                <StackPanel
                                    Grid.Row="5"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Button
                                        x:Name="CancelEditButton"
                                        Click="CancelEditButton_Click"
                                        Content="Limpiar" />
                                    <Button
                                        x:Name="SaveStudentButton"
                                        Padding="12,0"
                                        Click="SaveStudentButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Save" />
                                            <TextBlock Text="Guardar" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
